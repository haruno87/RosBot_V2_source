<launch>
  <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node" name="pc2ls">
    <remap from="cloud_in" to="/pointlio/cloud_registered"/>
    <remap from="scan"     to="/scan"/>
    <param name="target_frame" value="camera_init"/>
    <param name="min_height" value="0.2"/>
    <param name="max_height" value="0.3"/>
    <param name="range_min"  value="0.2"/>
    <param name="range_max"  value="10.0"/>
  </node>
</launch>